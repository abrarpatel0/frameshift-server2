{
  "version": "2.0.0",
  "description": "Pre-compiled Django-to-Flask conversion patterns for pattern-based (no-AI) conversion",
  "categories": {
    "imports": {
      "django.db": "from flask_sqlalchemy import SQLAlchemy",
      "django.db.models": "from flask_sqlalchemy import SQLAlchemy",
      "django.shortcuts": "from flask import render_template, redirect, url_for, abort, flash",
      "django.http": "from flask import request, jsonify, make_response, Response",
      "django.views": "from flask.views import MethodView",
      "django.urls": "from flask import url_for",
      "django.template": "# Flask uses Jinja2 natively",
      "django.contrib.auth": "from flask_login import login_required, current_user, login_user, logout_user",
      "django.contrib.auth.decorators": "from flask_login import login_required",
      "django.contrib.auth.mixins": "from flask_login import login_required",
      "django.conf": "import os",
      "django.core.exceptions": "from werkzeug.exceptions import NotFound, Forbidden, BadRequest",
      "django.forms": "from flask_wtf import FlaskForm\nfrom wtforms import StringField, PasswordField, BooleanField, TextAreaField, IntegerField, FloatField, DateField, SelectField, SubmitField\nfrom wtforms.validators import DataRequired, Email, Length, EqualTo, Optional, NumberRange",
      "django.utils": "# Check individual utility usage",
      "django.test": "import pytest\nfrom flask.testing import FlaskClient"
    },
    "decorators": {
      "@login_required": "@login_required",
      "@require_http_methods": "# Use @app.route methods parameter",
      "@csrf_exempt": "# Flask-WTF: use @csrf.exempt",
      "@cache_page": "# Use Flask-Caching: @cache.cached(timeout=...)",
      "@permission_required": "# Implement custom decorator with Flask-Login",
      "@user_passes_test": "# Implement custom decorator"
    },
    "view_functions": {
      "render(request, template, context)": "render_template(template, **context)",
      "redirect(url)": "redirect(url)",
      "HttpResponse(content)": "make_response(content)",
      "HttpResponseRedirect(url)": "redirect(url)",
      "HttpResponseNotFound()": "abort(404)",
      "HttpResponseForbidden()": "abort(403)",
      "HttpResponseBadRequest()": "abort(400)",
      "JsonResponse(data)": "jsonify(data)",
      "get_object_or_404(Model, pk=id)": "Model.query.get_or_404(id)",
      "get_list_or_404(Model)": "Model.query.all() or abort(404)"
    },
    "request_object": {
      "request.method": "request.method",
      "request.GET": "request.args",
      "request.POST": "request.form",
      "request.FILES": "request.files",
      "request.body": "request.data",
      "request.META": "request.headers",
      "request.user": "current_user",
      "request.user.is_authenticated": "current_user.is_authenticated",
      "request.session": "session",
      "request.COOKIES": "request.cookies",
      "request.path": "request.path",
      "request.get_full_path()": "request.full_path",
      "request.is_ajax()": "request.headers.get('X-Requested-With') == 'XMLHttpRequest'"
    },
    "template_tags": {
      "{% url 'name' %}": "{{ url_for('name') }}",
      "{% url 'name' arg %}": "{{ url_for('name', arg=arg) }}",
      "{% static 'path' %}": "{{ url_for('static', filename='path') }}",
      "{% csrf_token %}": "{{ form.hidden_tag() }}",
      "{% load static %}": "",
      "{% load i18n %}": "",
      "{% block content %}": "{% block content %}",
      "{% endblock %}": "{% endblock %}",
      "{% extends 'base.html' %}": "{% extends 'base.html' %}",
      "{% include 'partial.html' %}": "{% include 'partial.html' %}",
      "{% for item in items %}": "{% for item in items %}",
      "{% endfor %}": "{% endfor %}",
      "{% if condition %}": "{% if condition %}",
      "{% endif %}": "{% endif %}",
      "{% with var=value %}": "{% set var = value %}",
      "{% endwith %}": "",
      "{{ var|default:'value' }}": "{{ var|default('value') }}",
      "{{ var|length }}": "{{ var|length }}",
      "{{ var|date:'Y-m-d' }}": "{{ var.strftime('%Y-%m-%d') }}",
      "{{ var|truncatewords:30 }}": "{{ var|truncate(150) }}",
      "{{ var|linebreaks }}": "{{ var|replace('\\n', '<br>') }}",
      "{{ var|safe }}": "{{ var|safe }}",
      "{{ var|escape }}": "{{ var|e }}",
      "{{ var|lower }}": "{{ var|lower }}",
      "{{ var|upper }}": "{{ var|upper }}",
      "{{ var|title }}": "{{ var|title }}",
      "{{ var|join:', ' }}": "{{ var|join(', ') }}",
      "{{ var|filesizeformat }}": "# Implement custom filter",
      "{{ forloop.counter }}": "{{ loop.index }}",
      "{{ forloop.counter0 }}": "{{ loop.index0 }}",
      "{{ forloop.first }}": "{{ loop.first }}",
      "{{ forloop.last }}": "{{ loop.last }}"
    },
    "settings_mapping": {
      "DEBUG": "app.config['DEBUG']",
      "SECRET_KEY": "app.config['SECRET_KEY']",
      "DATABASES": "app.config['SQLALCHEMY_DATABASE_URI']",
      "STATIC_URL": "app.static_url_path",
      "STATIC_ROOT": "app.static_folder",
      "MEDIA_URL": "# Configure upload folder",
      "MEDIA_ROOT": "app.config['UPLOAD_FOLDER']",
      "TEMPLATES": "# Jinja2 auto-configured in Flask",
      "MIDDLEWARE": "# Use @app.before_request / @app.after_request",
      "INSTALLED_APPS": "# Register blueprints in app.py",
      "ROOT_URLCONF": "# Define routes in app.py or blueprints",
      "AUTH_PASSWORD_VALIDATORS": "# Implement in Flask-WTF validators",
      "LANGUAGE_CODE": "# Use Flask-Babel for i18n",
      "TIME_ZONE": "# Use pytz or datetime.timezone",
      "USE_I18N": "# Use Flask-Babel",
      "USE_TZ": "# datetime objects should be timezone-aware",
      "ALLOWED_HOSTS": "# Configure in web server (nginx/apache)",
      "CSRF_COOKIE_NAME": "app.config['WTF_CSRF_FIELD_NAME']",
      "LOGIN_URL": "login_manager.login_view",
      "LOGIN_REDIRECT_URL": "# Handle in login view",
      "EMAIL_BACKEND": "# Use Flask-Mail",
      "EMAIL_HOST": "app.config['MAIL_SERVER']",
      "EMAIL_PORT": "app.config['MAIL_PORT']"
    },
    "class_based_views": {
      "View": "MethodView (from flask.views)",
      "TemplateView": "# Use render_template in a function view",
      "ListView": "# def list_items(): return render_template('list.html', items=Model.query.all())",
      "DetailView": "# def detail(id): return render_template('detail.html', item=Model.query.get_or_404(id))",
      "CreateView": "# def create(): form = MyForm(); if form.validate_on_submit(): ...",
      "UpdateView": "# def update(id): item = Model.query.get_or_404(id); form = MyForm(obj=item); ...",
      "DeleteView": "# def delete(id): item = Model.query.get_or_404(id); db.session.delete(item); ...",
      "FormView": "# def form_view(): form = MyForm(); if form.validate_on_submit(): ...",
      "RedirectView": "# def redirect_view(): return redirect(url_for('target'))"
    },
    "url_patterns": {
      "path('route/', view)": "@app.route('/route/')",
      "path('route/<int:pk>/', view)": "@app.route('/route/<int:pk>/')",
      "path('route/<str:slug>/', view)": "@app.route('/route/<string:slug>/')",
      "path('route/<uuid:id>/', view)": "@app.route('/route/<uuid:id>/')",
      "re_path(r'^pattern$', view)": "# Use Flask converter or regex in route",
      "include('app.urls')": "app.register_blueprint(app_bp, url_prefix='/app')"
    },
    "model_fields": {
      "CharField": "db.Column(db.String({max_length}))",
      "TextField": "db.Column(db.Text)",
      "IntegerField": "db.Column(db.Integer)",
      "BigIntegerField": "db.Column(db.BigInteger)",
      "SmallIntegerField": "db.Column(db.SmallInteger)",
      "PositiveIntegerField": "db.Column(db.Integer)  # Add CheckConstraint",
      "FloatField": "db.Column(db.Float)",
      "DecimalField": "db.Column(db.Numeric(precision={max_digits}, scale={decimal_places}))",
      "BooleanField": "db.Column(db.Boolean, default=False)",
      "DateField": "db.Column(db.Date)",
      "DateTimeField": "db.Column(db.DateTime)",
      "TimeField": "db.Column(db.Time)",
      "EmailField": "db.Column(db.String(254))",
      "URLField": "db.Column(db.String(200))",
      "SlugField": "db.Column(db.String({max_length}))",
      "UUIDField": "db.Column(db.String(36))",
      "JSONField": "db.Column(db.JSON)",
      "BinaryField": "db.Column(db.LargeBinary)",
      "FileField": "db.Column(db.String(255))  # Store file path",
      "ImageField": "db.Column(db.String(255))  # Store image path",
      "ForeignKey": "db.Column(db.Integer, db.ForeignKey('{related_model}.id'))",
      "OneToOneField": "db.Column(db.Integer, db.ForeignKey('{related_model}.id'), unique=True)",
      "ManyToManyField": "# Requires association table"
    }
  },
  "complexity_scoring": {
    "simple_patterns": [
      "basic_model_with_fields_only",
      "simple_function_view",
      "basic_url_pattern",
      "static_file_copy",
      "init_file",
      "apps_config"
    ],
    "medium_patterns": [
      "model_with_relationships",
      "form_with_validation",
      "class_based_view",
      "url_with_nested_includes",
      "template_with_custom_tags"
    ],
    "complex_patterns": [
      "custom_middleware",
      "signal_handlers",
      "rest_framework_viewset",
      "custom_management_command",
      "celery_task_definitions",
      "custom_auth_backend",
      "multi_model_transaction"
    ]
  }
}
